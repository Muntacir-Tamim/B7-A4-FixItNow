model Booking {
  id              String        @id @default(uuid())
  scheduledDate   DateTime
  scheduledTime   String        @db.VarChar(10)
  address         String        @db.Text
  note            String?       @db.Text
  status          BookingStatus @default(REQUESTED)
  totalAmount     Float

  customerId String
  customer   User   @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Cascade)

  technicianProfileId String
  technicianProfile   TechnicianProfile @relation("TechnicianBookings", fields: [technicianProfileId], references: [id], onDelete: Cascade)

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  payment Payment?
  review  Review?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([technicianProfileId])
  @@index([serviceId])
  @@map("bookings")
}
